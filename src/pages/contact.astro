---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/navbar.astro';
import ContactForm from '../components/ContactForm.astro';
---
<head>
    <title>vejas.zip - contact</title>
<Layout>
  <Nav />
  <div class="p-2 space-y-10 text-center">
    <h1 class="text-text font-bold text-4xl mt-10 mb-5">Contact me if you dare</h1>
    <p class="text-xl">I'm always open to discussing new projects and ideas, or if you just want to chat!</p>
  </div>
  <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-8 min-h-[60vh] items-start px-4 max-w-6xl mx-50">
    <div class="w-full">
      <ContactForm client:load />
    </div>
    <div class="flex flex-col space-y-6">
      <div class="bg-gray-100/25 p-4 rounded shadow">
        <h2 class="text-2xl font-semibold mb-2">Find me on:</h2>

      </div>
</Layout>
