---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/navbar.astro';
import ContactForm from '../components/ContactForm.astro';
---
<head>
    <title>vejas.zip - contact</title>
<Layout>
  <Nav />
  <div class="p-0 space-y-8 text-center">
    <h1 class="text-text font-bold text-4xl mt-10 mb-0">Contact me</h1>
    <p class="pt-0 mt-0 text-gray-500">(If you dare)</p>
    <p class="text-xl">I'm always open to discussing new projects and ideas, or if you just want to chat!</p>
  </div>
  <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-8 min-h-[60vh] items-start px-4 max-w-6xl mx-auto">
    <div class="w-full">
      <ContactForm />
    </div>
    <div class="flex justify-center items-end ">
      <div class="flex flex-col w-full max-w-xl gap-4 bg-white p-5 rounded-xl border mb-10 border-gray-400/50">
        <div class="font-bold font-martian text-2xl text-start">Find me on</div>
        <div class="space-y-3">
          <div class="flex items-center">
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/github/github-original.svg" alt="GitHub logo" class="inline w-6 h-6 mr-2 align-middle"/>
            <a href="https://github.com/las-vejas" target="_blank" class="text-blue-600 text-lg hover:underline hover:decoration-wavy hover:text-blue-500">GitHub (@las-vejas)</a>
          </div>
          <div class="flex items-center">
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/slack/slack-original.svg" alt="Slack logo" class="inline w-6 h-6 mr-2 align-middle"/>
            <a href="" target="_blank" class="text-blue-600 text-lg hover:underline hover:decoration-wavy hover:text-blue-500">Hack Club Slack (@vejas)</a>
          </div>
          <div class="flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
            <path d="M125.4 128C91.5 128 64 155.5 64 189.4C64 190.3 64 191.1 64.1 192L64 192L64 448C64 483.3 92.7 512 128 512L512 512C547.3 512 576 483.3 576 448L576 192L575.9 192C575.9 191.1 576 190.3 576 189.4C576 155.5 548.5 128 514.6 128L125.4 128zM528 256.3L528 448C528 456.8 520.8 464 512 464L128 464C119.2 464 112 456.8 112 448L112 256.3L266.8 373.7C298.2 397.6 341.7 397.6 373.2 373.7L528 256.3zM112 189.4C112 182 118 176 125.4 176L514.6 176C522 176 528 182 528 189.4C528 193.6 526 197.6 522.7 200.1L344.2 335.5C329.9 346.3 310.1 346.3 295.8 335.5L117.3 200.1C114 197.6 112 193.6 112 189.4z"/>
          </svg>
          <a href="mailto:contact@vejas.site" target="_blank" class="text-blue-600 text-lg hover:underline hover:decoration-wavy hover:text-blue-500">Email me (contact@vejas.site)</a>
          </div>
          <div class="flex items-center">
            <img src="https://cdn.jsdelivr.net/npm/simple-icons@v11/icons/discord.svg" alt="Discord logo" class="inline w-6 h-6 mr-2 align-middle" style="color:#5865F2 fill:#5865F2"/>
            <a href="https://discord.com/users/lasvejas" target="_blank" class="text-blue-600 text-lg hover:underline hover:decoration-wavy hover:text-blue-500">Discord (@lasvejas)</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
