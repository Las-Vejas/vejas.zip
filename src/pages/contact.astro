---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/navbar.astro';
import ContactForm from '../components/ContactForm.astro';
---
<head>
    <title>vejas.zip - contact</title>
<Layout>
  <Nav />
  <div class="p-0 space-y-10 text-center">
    <h1 class="text-text font-bold text-4xl mt-10 mb-0">Contact me</h1>
    <p class="pt-0 mt-0 text-gray-500">(If you dare)</p>
    <p class="text-xl">I'm always open to discussing new projects and ideas, or if you just want to chat!</p>
  </div>
  <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-8 min-h-[60vh] items-start px-4 max-w-6xl mx-auto">
    <div class="w-full">
      <ContactForm client:load />
    </div>
    <div class="flex justify-center items-end ">
      <div class="flex flex-col w-full max-w-xl gap-4 bg-white p-5 rounded-xl border mb-10 border-gray-400/50">
        <div class="font-bold font-martian text-2xl text-start">Find me on</div>
        <div class="space-y-3">
          <div class="flex items-center">
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/github/github-original.svg" alt="GitHub logo" class="inline w-6 h-6 mr-2 align-middle"/>
            <a href="https://github.com/las-vejas" target="_blank" class="text-blue-600 text-lg hover:underline hover:decoration-wavy hover:text-blue-500">GitHub</a>
          </div>
          <div class="flex items-center">
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/slack/slack-original.svg" alt="Slack logo" class="inline w-6 h-6 mr-2 align-middle"/>
            <a href="" target="_blank" class="text-blue-600 text-lg hover:underline hover:decoration-wavy hover:text-blue-500">Hack Club Slack</a>
          </div>
          <div class="flex items-center">
          <img src="https://cdn.jsdelivr.net/npm/simple-icons@v11/icons/maildotru.svg" alt="Mail icon" class="inline w-6 h-6 mr-2 align-middle" style="fill:#EA4335; color:#EA4335;"/>
          <a href="mailto:contact@vejas.site" target="_blank" class="text-blue-600 text-lg hover:underline hover:decoration-wavy hover:text-blue-500">Email me</a>
          </div>
          <div class="flex items-center">
            <img src="https://cdn.jsdelivr.net/npm/simple-icons@v11/icons/discord.svg" alt="Discord logo" class="inline w-6 h-6 mr-2 align-middle" style="color:#5865F2 fill:#5865F2"/>
            <a href="https://discord.com/users/lasvejas" target="_blank" class="text-blue-600 text-lg hover:underline hover:decoration-wavy hover:text-blue-500">Discord</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
