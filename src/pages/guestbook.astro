---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import Navbar from '../components/navbar.astro';
import MessageForm from '../components/MessageForm.astro';
import Footer from '../components/footer.astro';
import { createClient } from "@supabase/supabase-js";
const supabase = createClient(
  import.meta.env.PRIVATE_SUPABASE_URL,
  import.meta.env.PRIVATE_SUPABASE_ANON_KEY
);

const { data: messages, error } = await supabase
  .from('messages')
  .select('*')
  .order('created_at', { ascending: false });
---
<head>
    <title>vejas.zip - guestbook</title>
</head>
<Layout>
<Navbar />
<div class="text-center space-y-10 mt-10">
<h1 class="text-text text-4xl font-bold text-center mt-10 mb-5">Guestbook</h1>
<p class="pt-0 mt-0 text-gray-500">(For beautiful messages about this website or just your thoughts)</p>
</div>

 <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-8 min-h-[60vh] items-start px-4 max-w-7xl mx-auto">
    <div class="w-full">
    <MessageForm />
    </div>
    <div class="flex justify-center items-end ">
      <div class="flex flex-col w-full max-w-7xl gap-4 bg-white p-5 rounded-xl border mb-10 border-gray-400/50">
        <div class="font-bold font-martian text-2xl text-start">Messages</div>

{error ? (
  <p style="color:red">Failed to load messages.</p>
) : null}
<ul class="pt-8 grid grid-cols-1 md:grid-cols-2 gap-4 px-4 w-full">
  {messages && messages.length > 0 ? (
    messages.map(msg => (
      <li class="min-w-[220px] max-w-[320px] rounded-lg p-4 bg-[rgba(255,255,255,0.02)] shrink-0 border border-black/20 shadow" style="margin-bottom:0;">
        <div class="text-lg font-semibold">{msg.name}</div>
        <div class="mt-1 text-base">{msg.message}</div>
        <small class="text-sm text-gray-400 mt-2 block">{new Date(msg.created_at).toLocaleString()}</small>
      </li>
    ))
  ) : (
    <li class="w-full p-4 text-center text-gray-400">No messages yet, why not write one?</li>
  )}
</ul>
      </div>
    </div>
  </div>
<Footer />

</Layout>