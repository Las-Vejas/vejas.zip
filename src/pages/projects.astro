---
import Nav from '../components/navbar.astro';
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import '../styles/global.css';
import { createClient } from "@supabase/supabase-js";

const supabase = createClient(
  import.meta.env.PRIVATE_SUPABASE_URL,
  import.meta.env.PRIVATE_SUPABASE_ANON_KEY
);

// Fetch projects from Supabase
const { data: projects, error } = await supabase
  .from('projects')
  .select('*')
  .order('category', { ascending: false });

if (error) {
  console.error('Error fetching projects:', error);
}

console.log('Projects data:', projects);
console.log('Projects count:', projects?.length || 0);
---
<head></head>
    <title>vejas.zip - projects</title>
</head>
<Layout>
<Nav />
<div class="px-auto space-x-2 space-y-4 text-left mx-auto"></div>
<h1 class="text-4xl font-bold text-center mt-10 mb-3">My Projects</h1>

<p class="text-center text-xl mx-10 my-4">I really like working on hardware projects (even though im a beginner at electronics). My projects consist of some (wannabe)keyboards and other little things. </p>

<div class="text-left mb-10 m-5 grid grid-cols-2 gap-4">
    {projects && projects.length > 0 ? (
        projects.map((project) => (
            <ProjectCard 
                title={project.title} 
                description={project.description} 
                link={project.link}
                secondLink={project.second_link}
                secondLinkText={project.second_link_text}
            />
        ))
    ) : (
        <p class="text-center">No projects found.</p>
    )}
</div>
</div>

</Layout>

<style>
    .h2 {
        margin-top: 1rem;
        margin-bottom: 0.5rem;
    }
</style>    